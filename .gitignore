.DS_Store
.claude
__pycache__/
*.pyc

# Per-run temp configs generated by run-k8s-suite.sh
p2p-coordinator/experiments/.workload-k8s-run.json
p2p-dht/experiments/.workload-k8s-run.json

# Multi-run result data (large, export to GCS instead)
p2p-coordinator/experiments/results-k8s-multi/
p2p-dht/experiments/results-k8s-multi/

# Aggregate outputs (regenerable from result data)
results-aggregate/

# Terraform local state
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
